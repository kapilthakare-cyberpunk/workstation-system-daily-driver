#!/bin/bash
# ~/bin/backup-home

BACKUP_DIR="$HOME/Backups/$(date +%Y%m%d)"
mkdir -p $BACKUP_DIR

echo "Starting essential backup to $BACKUP_DIR..."

tar -czf $BACKUP_DIR/home_essential.tar.gz \
  --exclude='*/node_modules' \
  --exclude='*/.git' \
  --exclude='*/target' \
  --exclude='*/__pycache__' \
  --exclude='*/venv' \
  --exclude='*/.cache' \
  ~/Documents \
  ~/Projects \
  ~/.zshrc \
  ~/.bashrc \
  ~/.config/nano \
  2>/dev/null

echo "Backup created: $BACKUP_DIR/home_essential.tar.gz"
