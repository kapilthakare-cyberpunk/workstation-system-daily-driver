    echo "║    whatsapp-business     → Business WhatsApp             ║"
    echo "║    whatsapp-automation   → Hastapop/Superchat/Automation ║"
    echo "║                                                          ║"
    echo "║  Fix Database Error:                                     ║"
    echo "║    whatsapp-fix-database → Clear corrupted data          ║"
    echo "║                                                          ║"
    echo "║  Manage:                                                 ║"
    echo "║    whatsapp-manager help → All commands                  ║"
    echo "║    whatsapp-manager status → Check profiles              ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
fi
alias adbcon="/home/kapilt/adb-wireless-manager/scripts/connect.sh"
alias adb-gui="python3 /home/kapilt/adb-wireless-manager/gui/adb_wireless_manager.py"

. "$HOME/.atuin/bin/env"

eval "$(atuin init zsh)"

# Use stable Flatpak LibreOffice for command-line tools
export PATH="$HOME/.local/bin:$PATH"
alias libreoffice='flatpak run org.libreoffice.LibreOffice'
alias libreoffice-writer='flatpak run org.libreoffice.LibreOffice --writer'
alias libreoffice-calc='flatpak run org.libreoffice.LibreOffice --calc'
alias libreoffice-impress='flatpak run org.libreoffice.LibreOffice --impress'
alias lo='flatpak run org.libreoffice.LibreOffice'
alias lo-headless='flatpak run org.libreoffice.LibreOffice --headless'

# LibreOffice MCP Server commands
alias lo-mcp-start='~/.mcp-libre/start-server.sh'
alias lo-mcp-status='tail -10 ~/mcp-extension.log'
alias lo-mcp-test='~/.mcp-libre/test-connection.sh'
alias memhog='watch -n 2 "ps -eo pid,ppid,cmd,%mem,%cpu --sort=-%mem | head -6"'

# Free Claude Code Automation
function claude-free() {
    local PROXY_DIR="/home/kapilt/Projects/free-claude-code"
    local PORT=8082
    
    # Start proxy in background if not already running on the port
    if ! lsof -i :$PORT > /dev/null 2>&1; then
        echo "[START] Starting Free Claude Code proxy..."
        (cd "$PROXY_DIR" && uv run uvicorn server:app --host 0.0.0.0 --port $PORT > /dev/null 2>&1 &)
        # Wait a moment for the server to spin up
        sleep 2
    fi
    
    # Launch Claude with the necessary environment variables
    # Pass any additional arguments through to the claude command
    ANTHROPIC_AUTH_TOKEN="freecc" ANTHROPIC_BASE_URL="http://localhost:$PORT" claude "$@"
}
