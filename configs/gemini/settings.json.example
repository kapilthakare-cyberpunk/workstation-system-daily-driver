{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "mcpServers": {
    "claude-mem": {
      "command": "/home/kapilt/.bun/bin/bun",
      "args": [
        "/home/kapilt/.claude/plugins/marketplaces/thedotmack/plugin/scripts/mcp-server.cjs"
      ]
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ]
    },
    "browsermcp": {
      "command": "npx",
      "args": [
        "@browsermcp/mcp@latest"
      ]
    },
    "skill-seeker": {
      "command": "/home/kapilt/Skill_Seekers/venv/bin/python3",
      "args": [
        "-m",
        "skill_seekers.mcp.server_fastmcp"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "claude-mem",
            "type": "command",
            "command": "\"/home/kapilt/.bun/bin/bun\" \"/home/kapilt/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs\" hook gemini-cli context",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "claude-mem",
            "type": "command",
            "command": "\"/home/kapilt/.bun/bin/bun\" \"/home/kapilt/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs\" hook gemini-cli session-init",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "claude-mem",
            "type": "command",
            "command": "\"/home/kapilt/.bun/bin/bun\" \"/home/kapilt/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs\" hook gemini-cli observation",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "claude-mem",
            "type": "command",
            "command": "\"/home/kapilt/.bun/bin/bun\" \"/home/kapilt/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs\" hook gemini-cli observation",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "claude-mem",
            "type": "command",
            "command": "\"/home/kapilt/.bun/bin/bun\" \"/home/kapilt/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs\" hook gemini-cli observation",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "claude-mem",
            "type": "command",
            "command": "\"/home/kapilt/.bun/bin/bun\" \"/home/kapilt/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs\" hook gemini-cli summarize",
            "timeout": 10000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "claude-mem",
            "type": "command",
            "command": "\"/home/kapilt/.bun/bin/bun\" \"/home/kapilt/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs\" hook gemini-cli observation",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "ui": {
    "footer": {
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "quota",
        "context-used",
        "memory-usage",
        "session-id",
        "auth",
        "token-count"
      ]
    }
  }
}